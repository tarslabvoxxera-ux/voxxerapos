{
  "name": "voxxera-pos-desktop",
  "productName": "Voxxera POS",
  "version": "1.0.0",
  "description": "Voxxera offline Point of Sale system",
  "repository": {
    "type": "git",
    "url": "https://github.com/iamsnh1/voxxera-pos.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac --x64",
    "postinstall": "electron-builder install-app-deps"
  },
  "author": "Voxxera",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "get-port": "^5.1.1"
  },
  "build": {
    "appId": "com.voxxerapos.desktop",
    "asar": true,
    "compression": "maximum",
    "publish": [
      {
        "provider": "github",
        "releaseType": "release"
      }
    ],

    "mac": {
      "category": "public.app-category.business",
      "target": [
        { "target": "dmg", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "build/icon.icns",
      "darkModeSupport": true,
      "hardenedRuntime": false
    },

    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Voxxera POS",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerLanguages": ["en_US"],
      "language": "1033"
    },

    "extraResources": [
      {
        "from": "../",
        "to": "www",
        "filter": [
          "**/*",
          "!desktop/**",
          "!.git/**",
          "!.github/**",
          "!node_modules/**",
          "!vendor/**",
          "!tests/**",
          "!design/**",
          "!docker/**",
          "!branding/**",
          "!*.sql",
          "!*.md",
          "!*.sh",
          "!*.ps1",
          "!Dockerfile",
          "!docker-compose*",
          "!.travis.yml",
          "!gulpfile.js",
          "!package.json",
          "!package-lock.json",
          "!composer.json",
          "!composer.lock",
          "!phpunit.xml.dist"
        ]
      },
      {
        "from": "bin",
        "to": "bin"
      }
    ]
  }
}
